# ============================================
# Sentinel SIEM — Environment Variables
# ============================================
# Copy this file to .env and fill in values for your environment.
# All variables have sensible defaults for local development.

# --- Database ---
DB_URL=jdbc:postgresql://localhost:5432/sentinel_db
DB_USERNAME=sentinel
DB_PASSWORD=sentinel_password

# --- RabbitMQ ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=user
RABBITMQ_PASS=password

# --- JWT ---
JWT_SECRET=SuperSecretDefaultKeyForLocalDevelopmentMakeSureItIs256BitsAtLeast000000000000000000

# --- CORS ---
CORS_ORIGINS=http://localhost:5173

# --- Spring ---
SPRING_PROFILES_ACTIVE=dev
